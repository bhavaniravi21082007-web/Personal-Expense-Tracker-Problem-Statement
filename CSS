body {
    font-family: Arial;
    background: #f4f4f4;
    display: flex;
    justify-content: center;
}

.container {
    background: white;
    padding: 20px;
    width: 400px;
    margin-top: 40px;
    border-radius: 8px;
    box-shadow: 0 0 10px gray;
}

h1, h2, h3 {
    text-align: center;
}

form input, form select, form button {
    width: 100%;
    padding: 10px;
    margin: 5px 0;
}

button {
    background: #28a745;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover {
    background: #218838;
}

ul {
    list-style: none;
    padding: 0;
}

li {
    background: #eee;
    padding: 10px;
    margin: 5px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.delete-btn {
    background: red;
    color: white;
    border: none;
    padding: 5px;
    cursor: pointer;
}
